# MarketMamba — Root .gitignore
# ================================

# Secrets — NEVER commit
.env
*.env
secrets.py

# 玉山證券 API 憑證與設定（含 API Key/Secret，2026-06-12 發現曾外流到 git 歷史）
玉山/
*.p12
*.ini

# Model checkpoints (too large)
**/*.pt
**/*.pth
**/*.ckpt

# Data directories (regenerate locally)
**/Data/processed_v6/
**/Data/raw_v6/
**/Data/cache_v6/
**/Data/*.parquet
**/Data/*.csv
Data/processed_v6.zip
Data/raw_cache/

# V6 result archives (dated subdirs only — root CSVs are committed)
V6/results/20*/

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.ipynb_checkpoints

# Frontend build artifacts
node_modules/
dist/
.vite/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Personal Obsidian vault (private notes, not for public repo)
market_mamba_note/

# Claude Code local settings (machine-specific permission grants)
.claude/

# Temporary debug / test output
app/backend/_api_check.txt
