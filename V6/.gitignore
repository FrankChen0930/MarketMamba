# MarketMamba V6 — Git Ignore
# ============================

# Environment & Secrets — NEVER commit these
.env
*.env
secrets.py

# Model checkpoints (too large for git)
models/*.pt
models/*.pth
models/*.ckpt

# Processed data (too large, regenerate locally)
/Data/processed_v6/
/Data/raw_v6/
/Data/cache_v6/

# Result archives (tracked via rolling window in results/ root only)
results/20*/

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
